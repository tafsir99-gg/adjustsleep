---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = "Terms of Service | Adjust Sleep";
const description = "Terms of Service for Adjust Sleep. Read the rules and guidelines for using our jet lag calculator.";
---

<Layout title={title} description={description}>
  <Navbar />
  <main class="flex-1 max-w-[800px] mx-auto w-full px-4 md:px-lg py-section">
    <div class="space-y-8">
      <div>
        <h1 class="font-sans font-semibold text-display-lg text-[var(--theme-ink)] tracking-tight mb-4">Terms of Service</h1>
        <p class="text-[var(--theme-body)]">Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
      </div>

      <div class="prose prose-invert max-w-none text-[var(--theme-body)] space-y-6">
        <h2 class="font-sans font-semibold text-body-lg text-[var(--theme-ink)]">1. Acceptance of Terms</h2>
        <p>By accessing and using Adjust Sleep, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our application.</p>

        <h2 class="font-sans font-semibold text-body-lg text-[var(--theme-ink)]">2. Medical Disclaimer</h2>
        <p><strong>Adjust Sleep is not a medical device or a substitute for professional medical advice.</strong> The schedules and melatonin timings provided are based on general circadian rhythm science. Always consult with a qualified healthcare provider before starting any new supplement regimen or significantly altering your sleep schedule, especially if you have an underlying medical condition.</p>

        <h2 class="font-sans font-semibold text-body-lg text-[var(--theme-ink)]">3. Accuracy of Information</h2>
        <p>While we strive to provide accurate mathematical calculations based on the Phase Response Curve, we make no guarantees regarding the effectiveness of the generated schedules for any individual user.</p>

        <h2 class="font-sans font-semibold text-body-lg text-[var(--theme-ink)]">4. Intellectual Property</h2>
        <p>The design, code, and content of Adjust Sleep are protected by copyright and other intellectual property laws.</p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
