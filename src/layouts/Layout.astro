---
interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Adjust Sleep | Jet Lag Calculator & Circadian Rhythm Shifter",
	description = "Learn how to adjust your sleep schedule and beat jet lag fast. Our free jet lag calculator uses phase response curve science and melatonin timing to safely reset your body clock."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="AdjustSleep" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://adjustsleep.com/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://adjustsleep.com/og-image.jpg" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://adjustsleep.com/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="https://adjustsleep.com/og-image.jpg" />
		<!-- Prevent FOUC for dark mode -->
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			};
			const isDark = getThemePreference() === 'dark';
			document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
		</script>

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-BD97GXZE5H" is:inline></script>
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());

		  gtag('config', 'G-BD97GXZE5H');
		</script>
	</head>
	<body class="bg-[var(--theme-canvas-soft)] text-[var(--theme-ink)] antialiased selection:bg-[var(--theme-ink)] selection:text-[var(--theme-canvas)] min-h-screen flex flex-col">
		<slot />
	</body>
</html>

<style>
	@import "../styles/app.css";
</style>
